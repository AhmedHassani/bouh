generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CONSULTANT
  CLIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PaymentMethod {
  REPRESENTATIVE
  ELECTRONIC
  PACKAGE
  PENDING
}

enum NotificationType {
  BOOKING_CONFIRMED
  APPOINTMENT_REMINDER
  SESSION_CANCELLED
  COUPON_EXPIRY
  ASSESSMENT_COMPLETED
  NEW_APPOINTMENT
  CHAT_MESSAGE
  RECOMMENDATION_RECEIVED
  GENERAL
}

// ─── Anonymous User ───────────────────────────────────────────────────────────

model AnonymousUser {
  id        String   @id @default(cuid())
  deviceId  String
  nickname  String
  createdAt DateTime @default(now())

  assessmentResults AnonAssessmentResult[]
  appointments      Appointment[]
  userPackages      UserPackage[]
  notifications     Notification[]
  fcmTokens         FcmToken[]
  conversations     Conversation[]

  @@unique([deviceId, nickname])
}

model AnonAssessmentResult {
  id            String        @id @default(cuid())
  anonUserId    String
  anonUser      AnonymousUser @relation(fields: [anonUserId], references: [id], onDelete: Cascade)
  assessmentId  String
  assessment    Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  totalScore    Int
  categoryLabel String?
  recommendation String?
  completedAt   DateTime      @default(now())

  answers      AnonAssessmentAnswer[]
  appointments Appointment[]

  @@unique([anonUserId, assessmentId])
}

model AnonAssessmentAnswer {
  id         String               @id @default(cuid())
  resultId   String
  result     AnonAssessmentResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  questionId String
  question   AssessmentQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  optionId   String
  option     QuestionOption       @relation(fields: [optionId], references: [id], onDelete: Cascade)
  score      Int
}

// ─── Core User ────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  phone     String?
  avatar    String?
  password  String?
  role      UserRole @default(CLIENT)
  locale    String   @default("ar")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile     ClientProfile?
  consultantProfile ConsultantProfile?
  notifications     Notification[]
  fcmTokens         FcmToken[]
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Client ───────────────────────────────────────────────────────────────────

model ClientProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments AssessmentResult[]
  bookings     Appointment[]
  reviews      Review[]
}

// ─── Consultant ───────────────────────────────────────────────────────────────

model ConsultantProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                   String?
  sessionPrice          Decimal  @default(0) @db.Decimal(10, 2)
  city                  String?
  yearsOfExperience     Int      @default(0)
  academicQualification String?
  certifications        String[]
  commissionRate        Decimal  @default(0.20) @db.Decimal(5, 4)
  rating                Decimal  @default(0) @db.Decimal(3, 2)
  totalReviews          Int      @default(0)
  isVerified            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  specializations  ConsultantSpecialization[]
  availability     Availability[]
  appointments     Appointment[]
  transferredAway  Appointment[] @relation("TransferredFrom")
  earnings         Earning[]
  reviews          Review[]
  timeOffs         ConsultantTimeOff[]
  sessionReports          SessionReport[]
  sessionRecommendations  SessionRecommendation[]
  bonuses                 Bonus[]
}

/// Bonus — discretionary admin-issued reward (separate from session earnings)
model Bonus {
  id           String   @id @default(cuid())
  consultantId String
  consultant   ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  amount       Decimal  @db.Decimal(12, 2)
  reason       String?
  status       BonusStatus @default(PENDING)
  createdById  String?   // admin user id who issued it
  paidAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([consultantId])
  @@index([status])
}

enum BonusStatus {
  PENDING
  PAID
  CANCELLED
}

/// SessionReport — private notes written by consultant after a session
/// Admin CANNOT read these. They belong to the consultant only.
model SessionReport {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  consultantId  String
  consultant    ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  content       String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([consultantId])
}

/// SessionRecommendation — recommendation from consultant to admin about a client
/// Visible to: consultant (writer) + admin. NOT visible to client.
model SessionRecommendation {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  consultantId  String
  consultant    ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  content       String   @db.Text
  isRead        Boolean  @default(false)
  readAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([consultantId])
  @@index([isRead])
}

model ConsultantTimeOff {
  id           String            @id @default(cuid())
  consultantId String
  consultant   ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  startDate    DateTime          @db.Date
  endDate      DateTime          @db.Date
  note         String?
  createdAt    DateTime          @default(now())
}

// ─── Specialization ───────────────────────────────────────────────────────────

model Specialization {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  consultants ConsultantSpecialization[]
}

model ConsultantSpecialization {
  consultantId     String
  consultant       ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  specializationId String
  specialization   Specialization    @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@id([consultantId, specializationId])
}

// ─── Availability ─────────────────────────────────────────────────────────────

model Availability {
  id            String            @id @default(cuid())
  consultantId  String
  consultant    ConsultantProfile @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  dayOfWeek     Int // 0=Sun … 6=Sat
  startTime     String // "09:00"
  endTime       String // "17:00"
  slotDuration  Int               @default(60) // minutes
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  blockedDates BlockedDate[]
}

model BlockedDate {
  id             String       @id @default(cuid())
  availabilityId String
  availability   Availability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  date           DateTime
  reason         String?
  createdAt      DateTime     @default(now())
}

// ─── Appointment ──────────────────────────────────────────────────────────────

model Appointment {
  id            String            @id @default(cuid())
  // Authenticated client (optional)
  clientId      String?
  client        ClientProfile?    @relation(fields: [clientId], references: [id])
  // Anonymous client (optional)
  anonUserId    String?
  anonUser      AnonymousUser?    @relation(fields: [anonUserId], references: [id])
  // Assessment result linked at booking
  assessmentResultId String?
  assessmentResult   AnonAssessmentResult? @relation(fields: [assessmentResultId], references: [id])

  consultantId  String
  consultant    ConsultantProfile @relation(fields: [consultantId], references: [id])
  scheduledAt   DateTime
  duration      Int               @default(60)
  status        AppointmentStatus @default(PENDING)
  originalPrice Decimal           @db.Decimal(10, 2)
  discountAmount Decimal          @default(0) @db.Decimal(10, 2)
  finalPrice    Decimal           @db.Decimal(10, 2)
  couponId      String?
  coupon        Coupon?           @relation(fields: [couponId], references: [id])
  paymentMethod PaymentMethod     @default(PENDING)
  paymentStatus PaymentStatus     @default(PENDING)
  paymentRef    String?
  // Link to the user-package this session was deducted from (if paid via package)
  userPackageId String?
  userPackage   UserPackage?      @relation(fields: [userPackageId], references: [id])
  // Required when paymentMethod = REPRESENTATIVE (rep visits client)
  clientAddress String?
  clientPhone   String?
  // Admin approval flow (for REPRESENTATIVE bookings)
  adminApproved   Boolean   @default(false)
  adminApprovedBy String?
  adminApprovedAt DateTime?
  // Transfer tracking — record who held this appointment before transfer
  transferredFromConsultantId String?
  transferredFromConsultant   ConsultantProfile? @relation("TransferredFrom", fields: [transferredFromConsultantId], references: [id])
  transferredAt   DateTime?
  transferredBy   String?
  transferReason  String?
  notes         String?
  cancelReason  String?
  cancelledBy   String?
  meetingLink   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  earning Earning?
  review  Review?
  sessionReport         SessionReport?
  sessionRecommendation SessionRecommendation?
  conversation          Conversation?
}

// ─── Packages ─────────────────────────────────────────────────────────────────

/// Package — admin-defined session bundle
model Package {
  id           String   @id @default(cuid())
  nameAr       String
  descriptionAr String?
  sessions     Int      // number of sessions in this package
  price        Decimal  @db.Decimal(10, 2) // total price in IQD
  icon         String?  @default("🌱")
  isFeatured   Boolean  @default(false)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userPackages UserPackage[]
}

/// UserPackage — a purchased package by an anonymous user
model UserPackage {
  id              String        @id @default(cuid())
  packageId       String
  package         Package       @relation(fields: [packageId], references: [id])
  anonUserId      String
  anonUser        AnonymousUser @relation(fields: [anonUserId], references: [id], onDelete: Cascade)

  totalSessions   Int           // snapshot at purchase time
  usedSessions    Int           @default(0)

  pricePaid       Decimal       @db.Decimal(10, 2)
  paymentMethod   PaymentMethod @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentRef      String?       // ZainCash transaction id

  purchasedAt     DateTime      @default(now())
  expiresAt       DateTime?     // optional expiry
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  appointments    Appointment[]

  @@index([anonUserId])
}

// ─── Coupon ───────────────────────────────────────────────────────────────────

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  expiresAt     DateTime?
  isActive      Boolean      @default(true)
  usageLimit    Int?
  usageCount    Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  appointments Appointment[]
}

// ─── Assessment ───────────────────────────────────────────────────────────────

model Assessment {
  id          String   @id @default(cuid())
  titleAr     String
  titleEn     String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   AssessmentQuestion[]
  results     AssessmentResult[]
  anonResults AnonAssessmentResult[]
  categories  ResultCategory[]
}

model AssessmentQuestion {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  textAr       String
  textEn       String
  order        Int
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  options      QuestionOption[]
  answers      AssessmentAnswer[]
  anonAnswers  AnonAssessmentAnswer[]
}

model QuestionOption {
  id         String             @id @default(cuid())
  questionId String
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  textAr     String
  textEn     String
  score      Int                @default(0)
  order      Int

  answers     AssessmentAnswer[]
  anonAnswers AnonAssessmentAnswer[]
}

model ResultCategory {
  id             String     @id @default(cuid())
  assessmentId   String
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  labelAr        String
  labelEn        String
  minScore       Int
  maxScore       Int
  description    String?
  recommendation String?
  createdAt      DateTime   @default(now())
}

model AssessmentResult {
  id            String        @id @default(cuid())
  assessmentId  String
  assessment    Assessment    @relation(fields: [assessmentId], references: [id])
  clientId      String
  client        ClientProfile @relation(fields: [clientId], references: [id])
  totalScore    Int
  categoryLabel String?
  completedAt   DateTime      @default(now())

  answers AssessmentAnswer[]
}

model AssessmentAnswer {
  id         String             @id @default(cuid())
  resultId   String
  result     AssessmentResult   @relation(fields: [resultId], references: [id], onDelete: Cascade)
  questionId String
  question   AssessmentQuestion @relation(fields: [questionId], references: [id])
  optionId   String
  option     QuestionOption     @relation(fields: [optionId], references: [id])
  score      Int
}

// ─── Earnings ─────────────────────────────────────────────────────────────────

model Earning {
  id               String            @id @default(cuid())
  consultantId     String
  consultant       ConsultantProfile @relation(fields: [consultantId], references: [id])
  appointmentId    String            @unique
  appointment      Appointment       @relation(fields: [appointmentId], references: [id])
  grossAmount      Decimal           @db.Decimal(10, 2)
  commissionAmount Decimal           @db.Decimal(10, 2)
  netAmount        Decimal           @db.Decimal(10, 2)
  isPaid           Boolean           @default(false)
  paidAt           DateTime?
  createdAt        DateTime          @default(now())
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id            String            @id @default(cuid())
  appointmentId String            @unique
  appointment   Appointment       @relation(fields: [appointmentId], references: [id])
  clientId      String
  client        ClientProfile     @relation(fields: [clientId], references: [id])
  consultantId  String
  consultant    ConsultantProfile @relation(fields: [consultantId], references: [id])
  rating        Int // 1–5
  comment       String?
  isVisible     Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  // Recipient — exactly one of userId / anonUserId must be set
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonUserId  String?
  anonUser    AnonymousUser?   @relation(fields: [anonUserId], references: [id], onDelete: Cascade)

  type        NotificationType
  title       String
  body        String
  data        Json?            // arbitrary payload — appointmentId, chatId, etc.
  link        String?          // deep-link to open in app

  isRead      Boolean          @default(false)
  readAt      DateTime?
  sentViaFcm  Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@index([anonUserId, isRead])
}

// ─── Push tokens (Firebase Cloud Messaging) ────────────────────────────────────

model FcmToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonUserId  String?
  anonUser    AnonymousUser? @relation(fields: [anonUserId], references: [id], onDelete: Cascade)
  platform    String?  // "web" | "android" | "ios"
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([anonUserId])
}

// ─── Chat ──────────────────────────────────────────────────────────────────────

/// A conversation between an anonymous client and admin staff,
/// scoped to a specific appointment (one conversation per session).
model Conversation {
  id              String   @id @default(cuid())
  appointmentId   String   @unique
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  anonUserId      String
  anonUser        AnonymousUser @relation(fields: [anonUserId], references: [id], onDelete: Cascade)

  lastMessageAt   DateTime @default(now())
  // Unread counters per side (incremented on send, reset on read)
  unreadByAnon    Int      @default(0)
  unreadByAdmin   Int      @default(0)
  closed          Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        Message[]

  @@index([anonUserId])
  @@index([lastMessageAt])
}

enum MessageSender {
  CLIENT
  ADMIN
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          MessageSender
  // If admin sent, capture which admin (for audit)
  senderUserId    String?
  content         String   @db.Text
  isRead          Boolean  @default(false)
  readAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([conversationId, createdAt])
}

// ─── Platform Settings ────────────────────────────────────────────────────────

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}
